{
  "name": "vscod-task-mcp",
  "displayName": "VSCode Task MCP",
  "description": "Expose VSCode tasks to AI coding assistants (Cline, etc.) via MCP",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.89.0"
  },
  "license": "MIT",
  "categories": [
    "Other"
  ],
  "keywords": [
    "mcp",
    "tasks",
    "cline",
    "task-runner"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {},
  "configuration": {
    "title": "VSCode Task MCP"
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run copy-bridge",
    "copy-bridge": "copyfiles -u 1 ./src/mcp-stdio-bridge.js ./out/",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.89.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "copyfiles": "^2.4.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.2.1"
  }
}
